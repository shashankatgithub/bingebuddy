import React, { useState } from "react";
import { View, Text, FlatList, Pressable, TouchableOpacity } from "react-native";
import { SafeAreaView } from "react-native-safe-area-context";
import Animated, {
  useSharedValue,
  useAnimatedStyle,
  withSpring,
} from "react-native-reanimated";

const artists = [
  { id: "1", name: "Taylor Swift" },
  { id: "2", name: "Ariana Grande" },
  { id: "3", name: "Ed Sheeran" },
  { id: "4", name: "Billie Eilish" },
  { id: "5", name: "Drake" },
  { id: "6", name: "BTS" },
  { id: "7", name: "Post Malone" },
  { id: "8", name: "Doja Cat" },
  { id: "9", name: "The Weeknd" },
  { id: "10", name: "Adele" },
  { id: "11", name: "Bruno Mars" },
  { id: "12", name: "Shawn Mendes" },
];

// Child component for each artist card
const ArtistCard = ({
  item,
  isSelected,
  handleSelectArtist,
}: {
  item: { id: string; name: string };
  isSelected: boolean;
  handleSelectArtist: (id: string) => void;
}) => {
  const scale = useSharedValue(1);

  const animatedStyle = useAnimatedStyle(() => ({
    transform: [{ scale: scale.value }],
  }));

  const onPress = () => {
    scale.value = withSpring(1.1, {}, () => {
      scale.value = withSpring(1);
    });
    handleSelectArtist(item.id);
  };

  return (
    <Animated.View
      style={animatedStyle}
      className="flex-1 m-2 rounded-lg overflow-hidden"
    >
      <Pressable
        className={`p-4 rounded-lg items-center justify-center ${
          isSelected ? "bg-blue-500" : "bg-gray-200"
        }`}
        onPress={onPress}
      >
        <Text
          className={`text-lg font-medium ${
            isSelected ? "text-white font-bold" : "text-black"
          }`}
        >
          {item.name}
        </Text>
      </Pressable>
    </Animated.View>
  );
};

const Artists = () => {
  const [selectedArtists, setSelectedArtists] = useState<string[]>([]);
  const doneScale = useSharedValue(1);

  const handleSelectArtist = (id: string) => {
    if (selectedArtists.includes(id)) {
      setSelectedArtists(selectedArtists.filter((artistId) => artistId !== id));
    } else {
      setSelectedArtists([...selectedArtists, id]);
    }
  };

  const handleDonePress = () => {
    doneScale.value = withSpring(1.2, {}, () => {
      doneScale.value = withSpring(1);
    });
    console.log("Done with artists:", selectedArtists);
  };

  const animatedDoneStyle = useAnimatedStyle(() => ({
    transform: [{ scale: doneScale.value }],
  }));

  return (
    <SafeAreaView className="flex-1 bg-white">
      <Text className="text-2xl font-bold text-center my-4">
        Choose Your Favorite Artists
      </Text>
      <FlatList
        data={artists}
        renderItem={({ item }) => (
          <ArtistCard
            item={item}
            isSelected={selectedArtists.includes(item.id)}
            handleSelectArtist={handleSelectArtist}
          />
        )}
        keyExtractor={(item) => item.id}
        numColumns={2}
        contentContainerStyle={{ paddingHorizontal: 10 }}
      />
      <View className="py-4 items-center">
        {selectedArtists.length >= 3 ? (
          <Animated.View
            style={animatedDoneStyle}
            className="bg-blue-500 px-6 py-3 rounded-full"
          >
            <TouchableOpacity onPress={handleDonePress}>
              <Text className="text-white text-lg font-bold">Done</Text>
            </TouchableOpacity>
          </Animated.View>
        ) : (
          <Text className="text-red-500 text-lg">
            Select at least {3 - selectedArtists.length} more artists
          </Text>
        )}
      </View>
    </SafeAreaView>
  );
};

export default Artists;
